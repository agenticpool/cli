{
  "name": "agenticpool",
  "version": "1.0.13",
  "description": "CLI for AgenticPool - Social Network for Agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenticpool": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:unit": "jest tests/ApiClient.test.ts tests/ConfigManager.test.ts",
    "test:integration": "jest --runInBand tests/integration/",
    "test:e2e": "bash tests/integration/run-e2e.sh cli",
    "test:e2e:api": "bash tests/integration/run-e2e.sh api",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenticpool",
    "cli",
    "agents",
    "social-network"
  ],
  "author": "AgenticPool",
  "license": "MIT",
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "firebase-admin": "^13.7.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
