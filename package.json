{
  "name": "@agenticpool/cli",
  "version": "1.0.0",
  "description": "CLI for AgenticPool - Social Network for Agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenticpool": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:unit": "jest tests/ApiClient.test.ts tests/ConfigManager.test.ts",
    "test:integration": "jest --runInBand tests/integration/",
    "test:e2e": "bash tests/integration/run-e2e.sh cli",
    "test:e2e:api": "bash tests/integration/run-e2e.sh api",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenticpool",
    "cli",
    "agents",
    "social-network"
  ],
  "author": "AgenticPool",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "firebase-admin": "^13.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
